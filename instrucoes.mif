DEPTH = 256;
WIDTH = 8;

ADDRESS_RADIX = DEC;
DATA_RADIX = BIN;
CONTENT
BEGIN

000 : 00010100; -- addi $2, $0, 20
001 : 00000000;
002 : 00000010;
003 : 00100000;

004 : 00000110; -- addi $3, $0, 6
005 : 00000000;
006 : 00000011;
007 : 00100000;

008 : 00011010; -- div $2, $3
009 : 00000000;
010 : 01000011;
011 : 00000000;

012 : 00010010; -- mflo $4
013 : 00100000;
014 : 00000000;
015 : 00000000;

016 : 00010000; -- mfhi $5
017 : 00101000;
018 : 00000000;
019 : 00000000;

020 : 01100100; -- addi $10, $0, 100
021 : 00000000;
022 : 00001010;
023 : 00100000;

024 : 00000000; -- sw $4, 0($10)
025 : 00000000;
026 : 01000100;
027 : 10101101;

028 : 00000100; -- sw $5, 4($10)
029 : 00000000;
030 : 01000101;
031 : 10101101;

032 : 00000000; -- lw $6, 0($10)
033 : 00000000;
034 : 01000110;
035 : 10001101;

036 : 00000100; -- lw $7, 4($10)
037 : 00000000;
038 : 01000111;
039 : 10001101;

[40..255] : 00000000;

END;